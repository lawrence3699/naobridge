.page-container {
  padding: 24rpx;
}

.page-title {
  text-align: center;
  margin-bottom: 24rpx;
  padding: 24rpx 0;
}

.section-title {
  margin-bottom: 20rpx;
  color: #2C5F8A;
}

.body-text {
  font-size: 16px;
  line-height: 1.8;
  color: #333333;
}

.principle-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #EEEEEE;
}

.principle-item:last-child {
  border-bottom: none;
}

.principle-icon {
  font-size: 28px;
  min-width: 48rpx;
}

.principle-content {
  flex: 1;
}

.principle-name {
  font-size: 16px;
  font-weight: bold;
  color: #1A1A1A;
  display: block;
}

.principle-desc {
  font-size: 14px;
  color: #666666;
  line-height: 1.6;
  display: block;
  margin-top: 4rpx;
}

.version-text {
  text-align: center;
  font-size: 14px;
  color: #999999;
  margin-top: 48rpx;
  padding-bottom: 48rpx;
}
