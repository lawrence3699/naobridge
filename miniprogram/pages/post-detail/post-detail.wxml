<view class="container" wx:if="{{post}}">
  <!-- Post Card -->
  <view class="post-section">
    <view class="post-header">
      <image class="avatar" src="{{post.author.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" />
      <view class="meta">
        <text class="username">{{post.author.nickName}}</text>
        <text class="time">{{postDate}}</text>
      </view>
      <text class="category-tag" wx:if="{{categoryLabel}}">{{categoryLabel}}</text>
    </view>

    <view class="post-title">{{post.title}}</view>

    <view class="post-body">
      <text class="content">{{post.content}}</text>
    </view>

    <view class="post-images" wx:if="{{post.images && post.images.length > 0}}">
      <image wx:for="{{post.images}}" wx:key="*this"
        src="{{item}}" mode="widthFix" class="detail-img"
        bindtap="onPreviewImage" data-url="{{item}}" />
    </view>

    <view class="post-stats">
      <view class="stat-item">{{post.viewCount}} 浏览</view>
      <view class="stat-item">{{post.likeCount}} 赞</view>
      <view class="stat-item">{{post.commentCount}} 评论</view>
    </view>

    <view class="post-actions">
      <view class="action-item" bindtap="onReport" data-type="post" data-id="{{post._id}}">举报</view>
      <view wx:if="{{isAuthor}}" class="action-item action-danger" bindtap="onDeletePost">删除</view>
    </view>
  </view>

  <!-- Comments Section -->
  <view class="comment-section">
    <view class="section-title">评论 ({{comments.length}})</view>

    <block wx:if="{{post.commentEnabled}}">
      <view class="comment-item" wx:for="{{comments}}" wx:key="_id">
        <view class="comment-header">
          <image class="comment-avatar" src="{{item.authorAvatar || '/images/default-avatar.png'}}" mode="aspectFill" />
          <view class="comment-meta">
            <text class="comment-user">{{item.authorName}}</text>
            <text class="comment-time">{{item.timeAgo}}</text>
          </view>
        </view>
        <text class="comment-content">{{item.content}}</text>

        <!-- Nested replies -->
        <view wx:if="{{item.replies && item.replies.length > 0}}" class="reply-list">
          <view wx:for="{{item.replies}}" wx:for-item="reply" wx:key="_id" class="reply-item">
            <text class="reply-author">{{reply.authorName}}</text>
            <text class="reply-text">: {{reply.content}}</text>
          </view>
        </view>

        <view class="comment-actions">
          <text class="action-link" bindtap="onReply" data-id="{{item._id}}" data-name="{{item.authorName}}">回复</text>
          <text class="action-link" bindtap="onReport" data-type="comment" data-id="{{item._id}}">举报</text>
        </view>
      </view>

      <view class="empty-tip" wx:if="{{comments.length === 0}}">还没有评论，来说两句吧</view>
    </block>

    <view class="empty-tip" wx:if="{{!post.commentEnabled}}">帖主已关闭评论</view>
  </view>
</view>

<!-- Loading -->
<view class="loading" wx:if="{{loading}}">加载中...</view>

<!-- Comment Input Bar -->
<view wx:if="{{post && post.commentEnabled}}" class="input-bar">
  <view class="reply-hint" wx:if="{{replyTo}}" bindtap="onCancelReply">
    回复 {{replyTo}} ✕
  </view>
  <view class="input-row">
    <input class="comment-input" placeholder="{{replyTo ? '回复 ' + replyTo + '...' : '写评论...'}}"
      value="{{commentText}}" bindinput="onCommentInput"
      confirm-type="send" bindconfirm="onSendComment" />
    <button class="send-btn" bindtap="onSendComment" disabled="{{!commentText.trim()}}">发送</button>
  </view>
</view>
