/* Post Detail — light blue card-based layout */

.container {
  padding: 20rpx;
  padding-bottom: 160rpx;
}

/* Post card */
.post-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 16rpx;
}

.post-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 16rpx;
  background: #eee;
}

.meta {
  flex: 1;
}

.username {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #444;
}

.time {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 4rpx;
}

.category-tag {
  font-size: 22rpx;
  color: #4A90D9;
  background: #EAF2FB;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.post-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.5;
}

.post-body {
  margin-bottom: 20rpx;
}

.content {
  font-size: 30rpx;
  line-height: 1.8;
  color: #444;
  white-space: pre-wrap;
}

.post-images {
  margin-bottom: 20rpx;
}

.detail-img {
  width: 100%;
  border-radius: 8rpx;
  margin-top: 16rpx;
}

.post-stats {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 20rpx;
  padding-top: 20rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
  font-size: 26rpx;
  color: #888;
}

.post-actions {
  display: flex;
  border-top: 1rpx solid #f0f0f0;
  margin-top: 16rpx;
  padding-top: 16rpx;
  gap: 32rpx;
}

.action-item {
  font-size: 26rpx;
  color: #888;
}

.action-danger {
  color: #e74c3c;
}

/* Comment section card */
.comment-section {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #444;
  margin-bottom: 24rpx;
}

.comment-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.comment-item:last-child {
  border-bottom: none;
}

.comment-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.comment-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  margin-right: 12rpx;
  background: #eee;
}

.comment-meta {
  flex: 1;
}

.comment-user {
  font-size: 26rpx;
  font-weight: 500;
  color: #444;
}

.comment-time {
  font-size: 22rpx;
  color: #888;
  margin-left: 12rpx;
}

.comment-content {
  font-size: 28rpx;
  line-height: 1.6;
  color: #444;
  padding-left: 68rpx;
}

/* Nested replies */
.reply-list {
  margin-top: 12rpx;
  margin-left: 68rpx;
  padding: 12rpx 16rpx;
  background: #F7F8FA;
  border-radius: 8rpx;
}

.reply-item {
  padding: 6rpx 0;
  font-size: 26rpx;
  line-height: 1.6;
}

.reply-author {
  color: #4A90D9;
  font-weight: 500;
}

.reply-text {
  color: #444;
}

.comment-actions {
  padding-left: 68rpx;
  margin-top: 10rpx;
  display: flex;
  gap: 24rpx;
}

.action-link {
  font-size: 24rpx;
  color: #4A90D9;
}

.empty-tip {
  text-align: center;
  padding: 40rpx;
  color: #888;
  font-size: 28rpx;
}

/* Loading */
.loading {
  text-align: center;
  padding: 80rpx;
  color: #888;
  font-size: 28rpx;
}

/* Comment input bar */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  border-top: 1rpx solid #eee;
  padding: 16rpx 20rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  z-index: 100;
}

.reply-hint {
  font-size: 24rpx;
  color: #4A90D9;
  padding: 8rpx 0;
}

.input-row {
  display: flex;
  align-items: center;
}

.comment-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 30rpx;
  padding: 16rpx 24rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  background: #4A90D9;
  color: #fff;
  border: none;
  font-size: 26rpx;
  padding: 12rpx 28rpx;
  border-radius: 30rpx;
}

.send-btn[disabled] {
  background: #B8D4EF;
  color: #fff;
}
