<view class="container">
  <view class="editor">
    <!-- Title -->
    <input class="title-input" placeholder="标题" value="{{title}}"
      bindinput="onTitleInput" maxlength="50" />

    <view class="divider"></view>

    <!-- Content -->
    <textarea class="content-input" placeholder="分享你的故事...（最少10字）"
      value="{{content}}" bindinput="onContentInput"
      maxlength="5000" auto-height />

    <!-- Category selector -->
    <view class="category-section">
      <view class="section-label">选择分类</view>
      <view class="category-list">
        <view wx:for="{{categories}}" wx:key="value"
          class="category-item {{selectedCategory === item.value ? 'category-active' : ''}}"
          bindtap="onSelectCategory" data-category="{{item.value}}">
          {{item.label}}
        </view>
      </view>
    </view>

    <!-- Image grid -->
    <view class="image-list" wx:if="{{images.length > 0}}">
      <view class="image-wrap" wx:for="{{images}}" wx:key="*this">
        <image src="{{item}}" mode="aspectFill" class="preview-img" />
        <view class="remove-btn" data-index="{{index}}" bindtap="onRemoveImage">✕</view>
      </view>
      <view class="add-img-btn" wx:if="{{images.length < 9}}" bindtap="onChooseImage">+</view>
    </view>
  </view>

  <!-- Bottom bar -->
  <view class="bottom-bar">
    <view class="tool-btn" bindtap="onChooseImage" wx:if="{{images.length === 0}}">图片</view>
    <view class="spacer"></view>
    <text class="char-count">{{content.length}}/5000</text>
    <button class="publish-btn" bindtap="onSubmit"
      disabled="{{!canSubmit || submitting}}">
      {{submitting ? '发布中...' : '发布'}}
    </button>
  </view>
</view>
