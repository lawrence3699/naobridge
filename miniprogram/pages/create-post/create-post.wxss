/* Create Post — light blue card-based layout */

.container {
  padding: 20rpx;
  padding-bottom: 48rpx;
}

.editor {
  background: #fff;
  border-radius: 12rpx;
  padding: 30rpx;
  min-height: 400rpx;
}

.title-input {
  width: 100%;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  padding: 12rpx 0;
}

.divider {
  height: 1rpx;
  background: #f0f0f0;
  margin: 16rpx 0;
}

.content-input {
  width: 100%;
  font-size: 30rpx;
  line-height: 1.6;
  color: #444;
  min-height: 300rpx;
}

/* Category selector */
.category-section {
  margin-top: 24rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.section-label {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 16rpx;
}

.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  font-size: 26rpx;
  color: #444;
  padding: 12rpx 24rpx;
  border: 1rpx solid #ddd;
  border-radius: 30rpx;
}

.category-active {
  color: #4A90D9;
  border-color: #4A90D9;
  background: #EAF2FB;
}

/* Image grid */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.image-wrap {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.remove-btn {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
}

.add-img-btn {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ddd;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 60rpx;
  color: #ccc;
}

/* Bottom bar */
.bottom-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 20rpx 30rpx;
  margin-top: 16rpx;
  border-radius: 12rpx;
}

.tool-btn {
  font-size: 28rpx;
  color: #888;
}

.spacer {
  flex: 1;
}

.char-count {
  font-size: 24rpx;
  color: #888;
  margin-right: 20rpx;
}

.publish-btn {
  background: #4A90D9;
  color: #fff;
  border: none;
  font-size: 28rpx;
  padding: 12rpx 36rpx;
  border-radius: 30rpx;
}

.publish-btn[disabled] {
  background: #B8D4EF;
  color: #fff;
}
