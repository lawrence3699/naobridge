/* Profile Page — Light Blue Card Theme */

.profile-page {
  min-height: 100vh;
  background-color: #F2F1F6;
  padding: 30rpx;
}

/* ---- Registration ---- */

.reg-title {
  font-size: 20px;
  font-weight: 600;
  color: #444;
  text-align: center;
  padding: 20rpx 0 30rpx;
}

.reg-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.form-group {
  margin-bottom: 30rpx;
}

.form-label {
  font-size: 14px;
  font-weight: 500;
  color: #444;
  margin-bottom: 12rpx;
}

.form-input {
  width: 100%;
  height: 80rpx;
  border: 1rpx solid #ddd;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 14px;
  color: #444;
  box-sizing: border-box;
  background: #FAFAFA;
}

.form-input:focus {
  border-color: #4A90D9;
  background: #fff;
}

/* Role selector */

.role-options {
  display: flex;
  gap: 16rpx;
  flex-wrap: wrap;
}

.role-option {
  flex: 1;
  min-width: 170rpx;
  padding: 18rpx 12rpx;
  border: 1rpx solid #ddd;
  border-radius: 12rpx;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  background: #FAFAFA;
  transition: all 0.2s;
}

.role-selected {
  border-color: #4A90D9;
  background: #EBF3FC;
}

.role-emoji {
  font-size: 24px;
}

.role-text {
  font-size: 13px;
  color: #444;
}

/* Rules checkbox */

.rules-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 8rpx 0;
}

.check-box {
  width: 36rpx;
  height: 36rpx;
  border: 1rpx solid #ccc;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 12px;
  color: #fff;
  flex-shrink: 0;
}

.checked {
  background-color: #4A90D9;
  border-color: #4A90D9;
}

.rules-link {
  font-size: 13px;
  color: #4A90D9;
}

/* Submit button */

.submit-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: #4A90D9;
  color: #fff;
  font-size: 16px;
  font-weight: 500;
  border: none;
  border-radius: 12rpx;
  margin-top: 16rpx;
  text-align: center;
}

.submit-btn[disabled] {
  background: #B8D4EE;
  color: #fff;
}

.submit-btn::after {
  border: none;
}

/* ---- Profile View ---- */

.profile-card {
  display: flex;
  align-items: center;
  gap: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  padding: 36rpx 30rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.avatar {
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: #E8E8E8;
  flex-shrink: 0;
}

.user-info {
  flex: 1;
  overflow: hidden;
}

.user-name {
  font-size: 18px;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-badge {
  display: inline-block;
  font-size: 12px;
  color: #fff;
  background: #4A90D9;
  padding: 4rpx 18rpx;
  border-radius: 20rpx;
}

/* Menu card */

.menu-card {
  background: #fff;
  border-radius: 16rpx;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 30rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.menu-item-last {
  border-bottom: none;
}

.menu-label {
  font-size: 15px;
  color: #444;
}

.menu-arrow {
  font-size: 18px;
  color: #ccc;
}

/* Disclaimer */

.disclaimer-bar {
  font-size: 12px;
  color: #888;
  text-align: center;
  padding: 36rpx 0 20rpx;
}

/* Loading overlay */

.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.85);
  z-index: 100;
}

.loading-label {
  font-size: 14px;
  color: #888;
}
