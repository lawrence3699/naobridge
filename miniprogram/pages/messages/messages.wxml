<!-- Messages / Notification Center Page -->
<view class="msg-page">
  <view class="page-header">消息中心</view>

  <block wx:if="{{messages.length > 0}}">
    <view
      wx:for="{{messages}}"
      wx:key="_id"
      class="msg-card {{!item.isRead ? 'msg-unread' : ''}}"
      bindtap="onOpenMessage"
      data-id="{{item._id}}"
      data-related="{{item.relatedId}}"
      data-type="{{item.type}}"
    >
      <view class="msg-top">
        <text class="msg-tag">{{item.typeLabel}}</text>
        <text class="msg-time">{{item.timeAgo}}</text>
      </view>
      <view class="msg-title">{{item.title}}</view>
      <view class="msg-preview">{{item.content}}</view>
    </view>
  </block>

  <view wx:if="{{!loading && messages.length === 0}}" class="msg-empty">
    <text class="msg-empty-text">暂无消息</text>
  </view>

  <view wx:if="{{loading}}" class="msg-loading">
    <text class="msg-loading-text">加载中...</text>
  </view>
</view>
