/* Messages Page — Light Blue Card Theme */

.msg-page {
  min-height: 100vh;
  background-color: #F2F1F6;
  padding: 30rpx;
}

.page-header {
  font-size: 20px;
  font-weight: 600;
  color: #444;
  text-align: center;
  padding: 10rpx 0 30rpx;
}

/* Message card */

.msg-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid transparent;
}

.msg-unread {
  border-left-color: #4A90D9;
}

.msg-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.msg-tag {
  font-size: 11px;
  color: #fff;
  background: #4A90D9;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.msg-time {
  font-size: 12px;
  color: #aaa;
}

.msg-title {
  font-size: 15px;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.msg-preview {
  font-size: 13px;
  color: #888;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

/* Empty & loading states */

.msg-empty,
.msg-loading {
  padding: 160rpx 0;
  text-align: center;
}

.msg-empty-text,
.msg-loading-text {
  font-size: 14px;
  color: #aaa;
}
