.page-container {
  padding: 24rpx;
}

.page-title {
  text-align: center;
  margin-bottom: 24rpx;
}

.message-card {
  margin-bottom: 16rpx;
}

.unread {
  border-left: 6rpx solid #2C5F8A;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.message-type-tag {
  font-size: 13px;
  color: #FFFFFF;
  background-color: #2C5F8A;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.message-time {
  font-size: 13px;
  color: #999999;
}

.message-title {
  font-size: 16px;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 8rpx;
}

.message-content {
  font-size: 15px;
  color: #666666;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.empty-state, .loading-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text, .loading-text {
  font-size: 16px;
  color: #999999;
}
