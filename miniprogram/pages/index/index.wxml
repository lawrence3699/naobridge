<!-- Home Page — Card-based post list with category tabs -->
<view class="page-container">

  <!-- Category tab bar -->
  <scroll-view class="tab-bar" scroll-x="true" enable-flex="true">
    <view
      wx:for="{{categories}}"
      wx:key="value"
      class="tab-item {{activeCategory === item.value ? 'tab-active' : ''}}"
      bindtap="onSwitchCategory"
      data-category="{{item.value}}"
    >
      <text>{{item.label}}</text>
    </view>
  </scroll-view>

  <!-- Post list (infinite scroll) -->
  <scroll-view
    class="post-scroll"
    scroll-y="true"
    bindscrolltolower="onScrollToLower"
    lower-threshold="200"
    refresher-enabled="{{true}}"
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onPullRefresh"
  >
    <block wx:if="{{posts.length > 0}}">
      <view
        wx:for="{{posts}}"
        wx:key="id"
        class="card post-card"
        bindtap="onOpenPost"
        data-id="{{item.id}}"
      >
        <!-- Card header: avatar + name + time -->
        <view class="card-header">
          <image
            class="avatar"
            src="{{item.avatarUrl || '/images/default-avatar.png'}}"
            mode="aspectFill"
          />
          <view class="header-info">
            <text class="author-name">{{item.authorName}}</text>
            <text class="post-time">{{item.timeAgo}}</text>
          </view>
          <text class="category-tag">{{item.categoryLabel}}</text>
        </view>

        <!-- Card body: title + content preview + images -->
        <view class="card-body">
          <view wx:if="{{item.title}}" class="post-title">{{item.title}}</view>
          <view class="post-content">{{item.contentPreview}}</view>

          <!-- Image grid -->
          <view wx:if="{{item.imageUrls.length > 0}}" class="image-grid image-count-{{item.imageUrls.length > 3 ? 'multi' : item.imageUrls.length}}">
            <image
              wx:for="{{item.imageUrls}}"
              wx:for-item="imgUrl"
              wx:key="*this"
              wx:if="{{index < 3}}"
              class="grid-image"
              src="{{imgUrl}}"
              mode="aspectFill"
              catchtap="onPreviewImage"
              data-url="{{imgUrl}}"
              data-urls="{{item.imageUrls}}"
            />
            <view wx:if="{{item.imageUrls.length > 3}}" class="more-images">
              +{{item.imageUrls.length - 3}}
            </view>
          </view>
        </view>

        <!-- Card footer: comment + like buttons -->
        <view class="card-buttons">
          <view class="btn-item">
            <text class="btn-icon">💬</text>
            <text class="btn-text">{{item.commentCount || 0}}</text>
          </view>
          <view class="btn-item">
            <text class="btn-icon">👍</text>
            <text class="btn-text">{{item.likeCount || 0}}</text>
          </view>
        </view>
      </view>
    </block>

    <!-- Empty state -->
    <view wx:if="{{!loading && posts.length === 0}}" class="empty-state">
      <text class="empty-text">还没有帖子，来发第一篇吧</text>
    </view>

    <!-- Loading indicator -->
    <view wx:if="{{loading}}" class="loading-state">
      <text class="loading-text">加载中...</text>
    </view>

    <!-- No more data -->
    <view wx:if="{{!hasMore && posts.length > 0 && !loading}}" class="no-more">
      <text class="no-more-text">没有更多了</text>
    </view>
  </scroll-view>

  <!-- FAB button -->
  <view class="fab-button" bindtap="onCreatePost">
    <text class="fab-icon">+</text>
  </view>

</view>
