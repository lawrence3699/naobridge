/* Home Page — Card-based forum layout, light blue theme */

.page-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F2F1F6;
}

/* Category tab bar */
.tab-bar {
  display: flex;
  white-space: nowrap;
  background-color: #fff;
  padding: 16rpx 12rpx;
  border-bottom: 1rpx solid #EFEFEF;
  flex-shrink: 0;
}

.tab-item {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 28rpx;
  margin: 0 8rpx;
  border-radius: 28rpx;
  font-size: 13px;
  color: #666;
  background-color: #F2F1F6;
  transition: all 0.2s;
}

.tab-active {
  background-color: #4A90D9;
  color: #fff;
  font-weight: bold;
}

/* Post scroll area */
.post-scroll {
  flex: 1;
  height: 0;
}

/* Post card */
.post-card {
  margin-bottom: 10rpx;
  padding: 24rpx 28rpx;
}

/* Card header */
.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.avatar {
  width: 68rpx;
  height: 68rpx;
  border-radius: 50%;
  background-color: #F2F1F6;
  flex-shrink: 0;
}

.header-info {
  flex: 1;
  margin-left: 16rpx;
  display: flex;
  flex-direction: column;
}

.author-name {
  font-size: 14px;
  color: #444;
  font-weight: 500;
}

.post-time {
  font-size: 11px;
  color: #888;
  margin-top: 2rpx;
}

.category-tag {
  font-size: 11px;
  color: #4A90D9;
  background-color: #EBF2FB;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  flex-shrink: 0;
}

/* Card body */
.card-body {
  padding: 0;
}

.post-title {
  font-size: 15px;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
  line-height: 1.5;
}

.post-content {
  font-size: 14px;
  color: #555;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* Image grid */
.image-grid {
  display: flex;
  gap: 8rpx;
  margin-top: 16rpx;
}

.grid-image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  background-color: #F2F1F6;
}

.image-count-1 .grid-image {
  width: 400rpx;
  height: 300rpx;
}

.more-images {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  background-color: #F2F1F6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 14px;
  color: #888;
}

/* Card footer buttons */
.card-buttons {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #F2F1F6;
  gap: 40rpx;
}

.btn-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.btn-icon {
  font-size: 14px;
}

.btn-text {
  font-size: 12px;
  color: #888;
}

/* States */
.empty-state {
  padding: 120rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 14px;
  color: #888;
}

.loading-state {
  padding: 40rpx 0;
  text-align: center;
}

.loading-text {
  font-size: 13px;
  color: #888;
}

.no-more {
  padding: 32rpx 0;
  text-align: center;
}

.no-more-text {
  font-size: 12px;
  color: #bbb;
}

/* FAB */
.fab-button {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 96rpx;
  height: 96rpx;
  background-color: #4A90D9;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(74, 144, 217, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 32px;
  color: #fff;
  line-height: 1;
  margin-top: -4rpx;
}
