/* Home Page Styles */
.page-container {
  padding-bottom: 140rpx;
}

/* Category Tabs */
.tab-bar {
  display: flex;
  white-space: nowrap;
  background-color: #FFFFFF;
  padding: 16rpx 8rpx;
  border-bottom: 1rpx solid #EEEEEE;
  position: sticky;
  top: 0;
  z-index: 10;
}

.tab-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  padding: 12rpx 24rpx;
  margin: 0 8rpx;
  border-radius: 12rpx;
  min-width: 44px;
  min-height: 44px;
  justify-content: center;
}

.tab-active {
  background-color: #E8F0F8;
  border: 2rpx solid #2C5F8A;
}

.tab-emoji {
  font-size: 20px;
}

.tab-label {
  font-size: 14px;
  color: #333333;
  margin-top: 4rpx;
}

.tab-active .tab-label {
  color: #2C5F8A;
  font-weight: bold;
}

/* Post Cards */
.post-list {
  padding: 8rpx 16rpx;
}

.post-card {
  margin-bottom: 16rpx;
}

.post-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.post-author {
  font-size: 14px;
  color: #666666;
}

.post-category-tag {
  font-size: 12px;
  color: #2C5F8A;
  background-color: #E8F0F8;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.post-title {
  margin-bottom: 8rpx;
}

.post-preview {
  font-size: 15px;
  color: #4A4A4A;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 3;
  overflow: hidden;
}

/* Image preview */
.post-images {
  display: flex;
  gap: 8rpx;
  margin-top: 12rpx;
}

.post-thumb {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  background-color: #F0F0F0;
}

.more-images {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
  background-color: #F0F0F0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 16px;
  color: #999999;
}

/* Post footer */
.post-footer {
  display: flex;
  gap: 24rpx;
  margin-top: 16rpx;
  align-items: center;
}

.post-stat {
  font-size: 13px;
  color: #999999;
}

.post-time {
  font-size: 13px;
  color: #999999;
  margin-left: auto;
}

/* States */
.empty-state, .loading-state {
  padding: 80rpx 0;
  text-align: center;
}

.empty-text, .loading-text {
  font-size: 16px;
  color: #999999;
}

.load-more {
  padding: 32rpx 0;
  text-align: center;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.load-more-text {
  font-size: 14px;
  color: #2C5F8A;
}

/* FAB */
.fab-button {
  position: fixed;
  right: 32rpx;
  bottom: 160rpx;
  width: 100rpx;
  height: 100rpx;
  background-color: #2C5F8A;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 16rpx rgba(44, 95, 138, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 36px;
  color: #FFFFFF;
  line-height: 1;
}

.footer-disclaimer {
  margin-top: 32rpx;
  margin-bottom: 32rpx;
}
