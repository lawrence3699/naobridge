/* Community Rules Page Styles */
.page-container {
  padding: 24rpx;
  padding-bottom: 160rpx;
}

.page-title {
  text-align: center;
  margin-bottom: 24rpx;
  padding: 24rpx 0;
}

.section-title {
  margin-bottom: 16rpx;
  color: #2C5F8A;
}

.body-text {
  font-size: 16px;
  line-height: 1.8;
  color: #333333;
}

.rule-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
}

.rule-number {
  font-size: 16px;
  font-weight: bold;
  color: #2C5F8A;
  min-width: 40rpx;
  margin-right: 12rpx;
}

.rule-text {
  font-size: 16px;
  line-height: 1.8;
  color: #333333;
  flex: 1;
}

.agree-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.agree-btn {
  width: 100%;
  font-size: 18px;
  padding: 20rpx 0;
  min-height: 48px;
}
