/* Global styles — NaoBridge light blue theme */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 14px;
  line-height: 1.6;
  color: #444;
  background-color: #F2F1F6;
}

/* Flex utilities */
.flex { display: flex; }
.flex-column { display: flex; flex-direction: column; }
.flex-row { display: flex; flex-direction: row; }
.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.align-center { align-items: center; }
.justify-between { justify-content: space-between; }
.justify-center { justify-content: center; }
.justify-end { justify-content: flex-end; }

/* Text utilities */
.text-primary { color: #444; }
.text-secondary { color: #888; }
.text-accent { color: #4A90D9; }
.text-bold { font-weight: bold; }
.text-center { text-align: center; }
.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* Font sizes */
.font-xs { font-size: 11px; }
.font-sm { font-size: 12px; }
.font-md { font-size: 14px; }
.font-lg { font-size: 16px; }
.font-xl { font-size: 18px; }

/* Spacing */
.m-0 { margin: 0; }
.p-0 { padding: 0; }
.mt-sm { margin-top: 8rpx; }
.mt-md { margin-top: 16rpx; }
.mt-lg { margin-top: 24rpx; }
.mb-sm { margin-bottom: 8rpx; }
.mb-md { margin-bottom: 16rpx; }
.mb-lg { margin-bottom: 24rpx; }
.ml-sm { margin-left: 8rpx; }
.ml-md { margin-left: 16rpx; }
.mr-sm { margin-right: 8rpx; }
.mr-md { margin-right: 16rpx; }
.p-sm { padding: 8rpx; }
.p-md { padding: 16rpx; }
.p-lg { padding: 24rpx; }

/* Card base */
.card {
  background-color: #fff;
  border-radius: 0;
  overflow: hidden;
}

/* Buttons */
button {
  margin: 0;
  padding: 0;
  background: none;
  border: none;
  font-size: inherit;
  line-height: inherit;
  color: inherit;
}

button::after {
  border: none;
}

.btn-primary {
  background-color: #4A90D9;
  color: #fff;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 32rpx;
  font-size: 14px;
}

.btn-primary:active {
  background-color: #3A7BC8;
}

/* Icon base (iconfont-style placeholders) */
.icon {
  display: inline-block;
  width: 36rpx;
  height: 36rpx;
  vertical-align: middle;
}

/* Divider */
.divider {
  height: 1rpx;
  background-color: #EFEFEF;
}

/* Separator between cards */
.card-separator {
  height: 10rpx;
  background-color: #F2F1F6;
}

/* Safe area bottom padding for pages with FAB or tabBar */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* Toast/feedback */
.feedback-success {
  color: #1A6B3C;
  background-color: #E8F5E9;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 13px;
}

.feedback-error {
  color: #8B1A1A;
  background-color: #FFEBEE;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  font-size: 13px;
}

/* Disclaimer */
.disclaimer {
  font-size: 12px;
  color: #888;
  background-color: #F2F1F6;
  padding: 16rpx 24rpx;
  text-align: center;
  line-height: 1.5;
}
