/* Global styles — NaoBridge accessibility defaults */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  font-size: 16px;
  line-height: 1.8;
  color: #1A1A1A;
  background-color: #F5F5F5;
}

/* Accessibility: minimum touch target 44x44px */
button, .clickable, navigator {
  min-width: 44px;
  min-height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* High contrast text */
.text-primary {
  color: #1A1A1A;
}

.text-secondary {
  color: #4A4A4A;
}

/* Headings — minimum 20px */
.heading-1 {
  font-size: 24px;
  font-weight: bold;
  line-height: 1.6;
  color: #1A1A1A;
}

.heading-2 {
  font-size: 20px;
  font-weight: bold;
  line-height: 1.6;
  color: #1A1A1A;
}

/* Buttons — accessible sizing */
.btn-primary {
  background-color: #2C5F8A;
  color: #FFFFFF;
  border: none;
  border-radius: 8rpx;
  padding: 12rpx 32rpx;
  font-size: 16px;
  min-height: 44px;
  min-width: 44px;
}

.btn-primary:active {
  background-color: #1E4468;
}

.btn-secondary {
  background-color: #FFFFFF;
  color: #2C5F8A;
  border: 2rpx solid #2C5F8A;
  border-radius: 8rpx;
  padding: 12rpx 32rpx;
  font-size: 16px;
  min-height: 44px;
  min-width: 44px;
}

/* Card container */
.card {
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

/* Toast/feedback styles */
.feedback-success {
  color: #1A6B3C;
  background-color: #E8F5E9;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 16px;
}

.feedback-error {
  color: #8B1A1A;
  background-color: #FFEBEE;
  padding: 16rpx 24rpx;
  border-radius: 8rpx;
  font-size: 16px;
}

/* Disclaimer banner */
.disclaimer {
  font-size: 14px;
  color: #666666;
  background-color: #FFF8E1;
  padding: 16rpx 24rpx;
  text-align: center;
  line-height: 1.6;
}
